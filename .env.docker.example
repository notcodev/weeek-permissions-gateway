# docker-compose env. Copy to .env (compose's default), fill in, then `docker compose up -d`.
# Never commit a populated copy.

# Public hostname. Caddy obtains TLS for this. Must resolve to the host running compose.
DOMAIN=gateway.example.com
ACME_EMAIL=ops@example.com

# Better Auth public URL — must equal https://${DOMAIN} in production.
BETTER_AUTH_URL=https://gateway.example.com

# Postgres credentials (used both inside and outside the container).
POSTGRES_DB=weeek_perm
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-strong-random

# Application secrets — generate each one with `pnpm genkey`.
BETTER_AUTH_SECRET=replace-with-32-bytes-base64
MASTER_KEY_ENC_KEY=replace-with-32-bytes-base64
FINGERPRINT_HMAC_PEPPER=replace-with-32-bytes-base64
SUB_KEY_HMAC_PEPPER=replace-with-32-bytes-base64
CRON_SECRET=replace-with-32-bytes-base64

# Optional.
WEEEK_API_BASE=https://api.weeek.net/public/v1
AUDIT_RETENTION_DAYS=90
LOG_LEVEL=info

# Google OAuth — leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
