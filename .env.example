DATABASE_URL=postgres://app:app@localhost:5432/weeek_perm
BETTER_AUTH_SECRET=replace-with-32-bytes-base64
BETTER_AUTH_URL=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development

# 32 random bytes, base64-encoded. Generate with `pnpm genkey`.
MASTER_KEY_ENC_KEY=replace-with-32-bytes-base64

# 32 random bytes, base64-encoded. Generate with `pnpm genkey`.
# Pepper for the workspace-uniqueness fingerprint. Different blast radius
# from MASTER_KEY_ENC_KEY — leaking this does not expose master keys.
FINGERPRINT_HMAC_PEPPER=replace-with-32-bytes-base64

# 32 random bytes, base64-encoded. Generate with `pnpm genkey`.
# Pepper for sub-key hashing. Sub-keys are stored as
# HMAC-SHA256(rawKey, SUB_KEY_HMAC_PEPPER) — leaking this lets an attacker
# verify guessed raw keys; rotating it invalidates every issued sub-key.
SUB_KEY_HMAC_PEPPER=replace-with-32-bytes-base64

# Weeek public API base. Override in tests.
WEEEK_API_BASE=https://api.weeek.net/public/v1
